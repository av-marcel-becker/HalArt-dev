<?php
   /**
    * Implements hook_page_attachments().
    */
   function av_mmenu_page_attachments(array &$attachments) 
      {
         if(!\Drupal::service('router.admin_context')->isAdminRoute()) 
            {
               $attachments['#attached']['library'][] = 'av_mmenu/av_mmenu';  
            }
      }
      