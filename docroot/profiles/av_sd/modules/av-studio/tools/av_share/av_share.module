               'facebook_profile_app_id' => $config->get('facebook_profile_app_id'),   
            /* -------------------------------------------------------------- */
            /* whatsapp */
            // share     
               'whatsapp_share_title' => $config->get('whatsapp_share_title'),
               'whatsapp_share_modified_title' => $config->get('whatsapp_share_modified_title'),
               'whatsapp_share_icon' => $config->get('whatsapp_share_icon'),  
            // profile  
               # 'whatsapp_profile_title' => $config->get('whatsapp_profile_title'),
               # 'whatsapp_profile_icon' => $config->get('whatsapp_profile_icon'),
            /* -------------------------------------------------------------- */
            /* pinterest */
            // share    
               'pinterest_share_title' => $config->get('pinterest_share_title'),
               'pinterest_share_icon' => $config->get('pinterest_share_icon'),
            // profile  
               'pinterest_profile_title' => $config->get('pinterest_profile_title'),
               'pinterest_profile_icon' => $config->get('pinterest_profile_icon'),  
            /* -------------------------------------------------------------- */
            /* linkedin */
            // share    
               'linkedin_share_title' => $config->get('linkedin_share_title'),
               'linkedin_share_icon' => $config->get('linkedin_share_icon'),
            // profile  
               'linkedin_profile_title' => $config->get('linkedin_profile_title'),
               'linkedin_profile_icon' => $config->get('linkedin_profile_icon'),
               'linkedin_profile_id' => $config->get('linkedin_profile_id'),      
            /* -------------------------------------------------------------- */
            /* xing */
            // share     
               'xing_share_title' => $config->get('xing_share_title'),
               'xing_share_icon' => $config->get('xing_share_icon'),
            // profile 
               'xing_profile_title' => $config->get('xing_profile_title'),
               'xing_profile_icon' => $config->get('xing_profile_icon'),
               'xing_profile_name' => $config->get('xing_profile_name'),
            /* -------------------------------------------------------------- */
            /* telegram */
            // share     
               'telegram_share_title' => $config->get('telegram_share_title'),
               'telegram_share_icon' => $config->get('telegram_share_icon'),
            // profile 
