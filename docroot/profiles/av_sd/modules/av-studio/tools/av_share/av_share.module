               'mail_misc_body' => $config->get('mail_misc_body'),
               'mail_misc_msg' => $config->get('mail_misc_msg'),
            /* -------------------------------------------------------------- */
            /* link */   
               'link_misc_title' => $config->get('link_misc_title'),
               'link_misc_icon' => $config->get('link_misc_icon'),
               'link_misc_copy' => $config->get('link_misc_copy'),
               'link_misc_close' => $config->get('link_misc_close'),
               'link_misc_msg' => $config->get('link_misc_msg'),
            /* -------------------------------------------------------------- */
            /* favorite */   
               'favorite_misc_title' => $config->get('favorite_misc_title'),
               'favorite_misc_icon' => $config->get('favorite_misc_icon'),
            /* -------------------------------------------------------------- */
            /* popup */  
               'popup_width' => $config->get('popup_width'),
               'popup_height' => $config->get('popup_height'),
               'popup_active' => $config->get('popup_active'),
            /* -------------------------------------------------------------- */
            /* menu */ 
               'menu_title' => $config->get('menu_title'),
               'menu_icon' => $config->get('menu_icon'),
               'menu_adjust_yn' => $config->get('menu_adjust_yn'),
               'menu_adjust_yp' => $config->get('menu_adjust_yp'),
               'menu_adjust_xn' => $config->get('menu_adjust_xn'),
               'menu_adjust_xp' => $config->get('menu_adjust_xp'),
               'menu_overlap' => $config->get('menu_overlap'),
               'menu_direction_top' => $config->get('menu_direction_top'),
               'menu_direction_left' => $config->get('menu_direction_left'),                 
            /* -------------------------------------------------------------- */
         ];         
         $attachments['#attached']['drupalSettings']['av_share'] = $data;
         
         $attachments['#attached']['library'][] = 'av_share/share';
      }
  

   # use Drupal\Component\Utility\Xss;
   use Drupal\Component\Utility\Html; 
   
   /**
    * Implements hook_token_info().
    */
   function av_share_token_info() 
      {        
        $info = [];
        $info['types']['av_share'] = [
                                             'name' => t('AV Share'), 
                                             'description' => t('share tokens')
                                          ];
         $info['tokens']['av_share']['share:'] = [
                                                         'name' => t('full url'), 
                                                         'description' => t('url'),
                                                         0 => '0'
                                                      ];
         $info['tokens']['av_share']['url:full_path'] = [
                                                               'name' => t('full url path'), 
                                                               'description' => t('only path with parameters'),
                                                               0 => '0'
                                                            ];                                
                                                                             
        return $info;
      }
      
   /**
    * Implements hook_tokens().
    */
   function  av_share_tokens($type, $tokens, array $data, array $options, \Drupal\Core\Render\BubbleableMetadata $bubbleable_metadata) 
      {
         $replacements = [];
         if($type == 'av_share') 
            {
               foreach ($tokens as $name => $original) 
                  {
                     Global $base_url;
                     // Find the desired token by name.
                     switch ($name) 
                        {
                           case 'url:full': 
                              $results['url']['full'] = $base_url;
                              $replacements[$original] = (isset($results['url']['full']))?$results['url']['full']:'';
                           break;
                           case 'url:full_path': 
                              $results['url']['full_path'] = Html::escape($_SERVER['REQUEST_URI']);
                              $replacements[$original] = (isset($results['url']['full_path']))?$results['url']['full_path']:'';                                        
                           break;
                        }
                  }
            }
         return $replacements;
      }
     