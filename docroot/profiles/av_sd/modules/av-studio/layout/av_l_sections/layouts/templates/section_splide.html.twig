{% set container_attributes = attributes %}

{% if region_wrapper_attributes %}

{% else %}
   {% set region_wrapper_attributes = create_attribute() %}
{% endif %}

{% if region_attributes.region_1 %}
   {% set region_attributes_region_1 = region_attributes.region_1 %}
{% else %}
   {% set region_attributes_region_1 = create_attribute() %}
{% endif %}

{% 
   set container_classes = [
         'section-splide-slider',
         'w-100',
         (settings.section_background_color.color in settings.default_settings.colors_with_class_array.section|keys)?settings.default_settings.colors_with_class_array.section[settings.section_background_color.color], 
         (settings.section_custom is iterable)?settings.section_custom|filter(item => item != 0)|join(' '),
      ]  
%}

{% 
   set region_wrapper_classes = [
      ]  
%}


{% 
   set  region_classes_region_1 = [
         ('layout-paragraphs-builder' not in path('<current>') and 'add' not in path('<current>') and 'edit' not in path('<current>') and 'block' not in path('<current>'))?'splide':'',
      ] 
%}


{% if settings.default_settings.active_section_id and settings.section_id %}
   {% set container_attributes = container_attributes.setAttribute('id', settings.section_id) %}
{% endif %}

<div{{ container_attributes.addClass(container_classes) }}>
   <section{{ region_attributes_region_1.addClass(region_classes_region_1) }} aria-label="Slider" 
      data-splide='{
           "type": "loop",
           "drag": "free",
           "snap": true,
           "speed": 1000,
           "direction": "ltr",
           "paginationDirection": "ltr",
           "wheel": false,
           "perPage": 1,
           "perMove": 1,
           "gap": 0,
           "breakpoints": {
             "1200": {
               "perPage": 1,
               "perMove": 1,
               "gap": 0
             },
             "992": {
               "perPage": 1,
               "perMove": 1,
               "gap": 0
             },
             "768": {
               "perPage": 1,
               "perMove": 1,
               "gap": 0
             },
             "576": {
               "perPage": 1,
               "perMove": 1,
               "gap": 0
             }
           }
         }'>

      {% if ('layout-paragraphs-builder' not in path('<current>') and 'add' not in path('<current>') and 'edit' not in path('<current>') and 'block' not in path('<current>')) %}  
         {% if content.region_1 %}  
              {#  <ul class="splide__pagination"></ul> #}                                                       
              <div class="splide__track">
                <ul class="splide__list">
                  {% for key, item in content.region_1 %}
                     {% if key matches '/^\\d+$/' %}
                       <li class="splide__slide">
                         {{ item }}
                       </li>
                     {% endif %}
                  {% endfor %}

                </ul>
              </div>
              {# <div class="splide__arrows"></div> #}                                                 
              {#  <ul class="splide__pagination"></ul> #} 
         {% endif %}
      {% else %}
         {{ content.region_1 }}
      {% endif %}
   </section>
</div>

