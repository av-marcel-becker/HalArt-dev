{#
/**
 * @file
 * Claro's theme implementation to display a single Drupal page.
 *
 * The doctype, html, head, and body tags are not in this template. Instead
 * they can be found in the html.html.twig template normally located in the
 * core/modules/system directory.
 *
 * Available variables:
 *
 * General utility variables:
 * - base_path: The base URL path of the Drupal installation. Will usually be
 *   "/" unless you have installed Drupal in a sub-directory.
 * - is_front: A flag indicating if the current page is the front page.
 * - logged_in: A flag indicating if the user is registered and signed in.
 * - is_admin: A flag indicating if the user has permission to access
 *   administration pages.
 *
 * Site identity:
 * - front_page: The URL of the front page. Use this instead of base_path when
 *   linking to the front page. This includes the language domain or prefix.
 *
 * Page content (in order of occurrence in the default page.html.twig):
 * - node: Fully loaded node, if there is an automatically-loaded node
 *   associated with the page and the node ID is the second argument in the
 *   page's path (e.g. node/12345 and node/12345/revisions, but not
 *   comment/reply/12345).
 *
 * Regions:
 * - page.header: Items for the header region.
 * - page.pre_content: Items for the pre-content region.
 * - page.breadcrumb: Items for the breadcrumb region.
 * - page.highlighted: Items for the highlighted region.
 * - page.help: Dynamic help text, mostly for admin pages.
 * - page.content: The main content of the current page.
 *
 * @see template_preprocess_page()
 * @see html.html.twig
 */
         <av-header-logo-main></av-header-logo-main> 
         <av-header-logo-secondary></av-header-logo-secondary> 
         <av-header-menu-main></av-header-menu-main> 
         <av-header-menu-secondary></av-header-menu-secondary> 
#}
   {% if page.header %}
      {% set setup_height_mobile = drupal_config('av_header.settings', 'setup_height_mobile') %}
      {% set setup_height_desktop = drupal_config('av_header.settings', 'setup_height_desktop') %}
      {% set setup_position_static = drupal_config('av_header.settings', 'setup_position_static') %}
      {% set setup_background = drupal_config('av_header.settings', 'setup_background') %}
      {% set setup_border_bottom = drupal_config('av_header.settings', 'setup_border_bottom') %}
      {% set setup_shadow = drupal_config('av_header.settings', 'setup_shadow') %}
      <av-header class="page-header cssf" 
                 height-mobile="{{ setup_height_mobile }}" 
                 height-desktop="{{ setup_height_desktop }}" 
                 position-static="{{ setup_position_static }}" 
                 background="{{ setup_background }}" 
                 border-bottom="{{ setup_border_bottom }}"
                 shadow="{{ setup_shadow }}">  
         {% set setup_items_count = drupal_config('av_header.settings', 'setup_items_count') %}
         {% set setup_split_symbol_link = drupal_config('av_header.settings', 'setup_split_symbol_link') %}
         {% set setup_items_active = drupal_config('av_header.settings', 'setup_items_active') %}
         {% if setup_items_active and setup_items_count > 0 %}
               <nav class="cssf--d_inline-block">
                  <ul class="cssf--d_inline-block--list-style_none--m0--p0">
                     {% for i in 1..setup_items_count %}
                        {% set item_active = drupal_config('av_header.settings', 'item_'~loop.index~'_active') %}
                           {% if item_active  %}   
                              <li class="cssf--d_inline-block--m0--p0">    
                                 {% set item_accessibility_type = drupal_config('av_header.settings', 'item_'~loop.index~'_av_accessibility_type') %}
                                 {% set item_accessibility_settings = drupal_config('av_header.settings', 'item_'~loop.index~'_av_accessibility_settings') %}
                                 {% set item_href = drupal_config('av_header.settings', 'item_'~loop.index~'_href') %}
                                 {% set item_a_title = drupal_config('av_header.settings', 'item_'~loop.index~'_a_title') %}
                                 {% set item_a_target = drupal_config('av_header.settings', 'item_'~loop.index~'_a_target') %}
                                 {% set item_a_class = drupal_config('av_header.settings', 'item_'~loop.index~'_a_class') %}
                                 {% set item_label = drupal_config('av_header.settings', 'item_'~loop.index~'_label') %}
                                 {% set item_icon = drupal_config('av_header.settings', 'item_'~loop.index~'_icon') %}
                                 {% set item_av_accessibility = drupal_config('av_header.settings', 'item_'~loop.index~'_av_accessibility') %}
                                 {% if item_av_accessibility  %}   
                                    <av-accessibility type="{{ item_accessibility_type }}" settings="{{ item_accessibility_settings }}" class="{{ item_a_class }}" data-icon="{{ item_icon }}"><span class="accessibility-focus-target">{{ item_label|t({'langcode': 'de'}) }}</span></av-accessibility>
                                 {% else %}
                                    <a href="{{ item_href }}" title="{{ item_a_title|t({'langcode': 'de'}) }}" rel="nofollow" target="{{ item_a_target }}" class="{{ item_a_class }}"><span class="icon" data-icon="{{ item_icon }}"></span><span class="label">{{ item_label|t({'langcode': 'de'}) }}</span></a>
                                 {% endif %}
                                 {% if not loop.last %} {{ setup_split_symbol_link|raw }} {% endif %}
                              </li>                           
                           {% endif %}
                     {% endfor %}
                  </ul>         
               </nav>    
            {% endif %}   
         {{ page.header }} 
      </av-header> 
   {% endif %}   
   <main role="main" class="page-content cssf" id="main-content">  
      {{ page.content }}  
   </main>  
   {% if page.footer %}
      <footer class="page-footer cssf">    
         {{ page.footer }}
         <div class="page-copyright">
            <span class="page-copyright-text">
               {% set setup_show_copyright_icon = drupal_config('av_copyright.settings', 'setup_show_copyright_icon') %}
               {% set setup_year_right = drupal_config('av_copyright.settings', 'setup_year_right') %}
               {% set setup_text = drupal_config('av_copyright.settings', 'setup_text') %}
               {% set setup_current_year = drupal_config('av_copyright.settings', 'setup_current_year') %}
               {% set setup_count_up_the_year = drupal_config('av_copyright.settings', 'setup_count_up_the_year') %}
               {% set setup_split_symbol = drupal_config('av_copyright.settings', 'setup_split_symbol') %}
               {% set setup_split_symbol_link = drupal_config('av_copyright.settings', 'setup_split_symbol_link') %}
               {% if setup_show_copyright_icon %}&copy; {% endif %}
               {% if setup_year_right %}{{ setup_text }} {% endif %}
                  {{ setup_current_year }}
                  {% set currentYear = date('Y')|date('Y') %}
                  {% if setup_count_up_the_year and currentYear != setup_current_year %} - {{ currentYear }} {% endif %}
               {% if not setup_year_right %}{{ setup_text }} {% endif %}
            </span> {{ setup_split_symbol|raw }} 
            {% set items_count = drupal_config('av_copyright.settings', 'setup_items_count') %}
            {% if items_count > 0 %}
               <nav class="cssf--d_inline-block">
                  <ul class="cssf--d_inline-block--list-style_none--m0--p0">
                     {% for i in 1..items_count %}
                        <li class="cssf--d_inline-block--m0--p0">
                           <a href="{{ drupal_config('av_copyright.settings', 'item_'~loop.index~'_a_href') }}" title="{{ drupal_config('av_copyright.settings', 'item_'~loop.index~'_a_title') }}" rel="nofollow" target="{{ drupal_config('av_copyright.settings', 'item_'~loop.index~'_a_target') }}">{{ drupal_config('av_copyright.settings', 'item_'~loop.index~'_a_label') }}</a>
                           {% if not loop.last %} {{ setup_split_symbol_link|raw }} {% endif %}
                        </li>
                     {% endfor %}
                  </ul>         
               </nav>    
            {% endif %}     
         </div>         
      </footer> 
   {% endif %}  
   {% if page.hidden_footer %}
      <div class="page-hidden-footer cssf--d_none">
         {{ page.hidden_footer }}
         <span id="block-b-mobile-menu-menu">Menü</span>
         <span id="block-b-menu-main-menu">Menü</span>
         <span id="block-b-menu-account-menu">Benutzer Menü</span>
      </div>
   {% endif %} 


